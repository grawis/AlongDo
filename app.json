{
  "expo": {
    "name": "AlongDo",
    "slug": "alongdo",
    "version": "1.0.0",
    "icon": "./assets/icon-source.png",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "sdkVersion": "56.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.alongdo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-source.png",
        "backgroundColor": "#f6fbff"
      }
    },
    "plugins": [
      "expo-status-bar"
    ]
  }
}
